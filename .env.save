DATABASE_URL="postgresql://tanishka@localhost:5432/grably?schema=public"# ---------------------------------------------------------------------------
# Grably environment configuration. Copy to `.env` and fill in.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (required).
# Local:   postgresql://postgres:postgres@localhost:5432/grably?schema=public
# Hosted:  use the URL from Neon / Supabase / Railway / RDS, etc.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/grably?schema=public"

# Where finished files are written. Use a persistent/mounted volume in prod.
# (Also accepts STORAGE_URL as an alias.)
STORAGE_DIR="./downloads"

# Path to the yt-dlp binary if it isn't on PATH.
YT_DLP_PATH="yt-dlp"

# ----- Resource limits & safety ------------------------------------------------
MAX_FILE_SIZE="500M"            # yt-dlp --max-filesize ceiling per download
DOWNLOAD_TIMEOUT_MS="300000"    # kill a stuck download after N ms (5 min)
MAX_CONCURRENT_JOBS="3"         # max simultaneous yt-dlp processes
FILE_TTL_MS="3600000"           # auto-delete finished files after N ms (1 h); 0 = keep

# ----- Rate limiting (per IP) --------------------------------------------------
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="20"

# ----- Auth & sessions --------------------------------------------------------
# Secret used to sign session / guest cookies (HMAC). REQUIRED in production.
# Generate one with:  openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string"

# Cookie names (override only if they collide with something else).
SESSION_COOKIE="grably_session"
GUEST_COOKIE="grably_guest"

# How long a login session stays valid (ms). Default 30 days.
SESSION_TTL_MS="2592000000"

# ----- Free trial -------------------------------------------------------------
# Downloads an anonymous visitor gets before they must create an account.
TRIAL_LIMIT="3"

# ----- Optional: external API keys / storage providers ------------------------
# Reserved for future use (e.g. S3/R2 offload, captcha, analytics).
# API_KEYS=""
# STORAGE_URL=""
